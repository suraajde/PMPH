# =========================================================
# PMPH - Git Ignore
# =========================================================

# Python cache
__pycache__/
*.py[cod]
*$py.class

# Virtual environment
.venv/
venv/
env/

# Streamlit
.streamlit/secrets.toml

# VS Code / IDE
.vscode/
.idea/

# Operating system files
.DS_Store
Thumbs.db

# =========================================================
# PRIVATE PORTFOLIO / BROKER DATA
# =========================================================

# Never commit real holdings/import files
data/*.xlsx
data/*.xls
data/*.csv

# Temporary/import files
*.tmp
~$*.xlsx
~$*.xls

# Environment / secrets
.env
.env.*
*.key
*.pem
# Local AI / agent workspace files
.agents/
# Local PMPH databases
data/*.db
data/*.db-journal
data/*.db-shm
data/*.db-wal
# Python
__pycache__/
*.py[cod]

# Virtual environment
.venv/

# PMPH local databases
data/*.db
data/**/*.db
*.db-journal
*.db-wal
*.db-shm

# PMPH database backups and test artifacts
data/backups/
data/backup_test/
data/test_batch_backups/

# Local holding statements / portfolio data
data/*.xlsx
data/*.xls
data/*.csv

# Temporary files
*.tmp
~$*